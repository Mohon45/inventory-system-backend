generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  username     String        @unique @db.VarChar(50)
  createdAt    DateTime      @default(now()) @map("created_at")
  reservations Reservation[]
  purchases    Purchase[]

  @@map("users")
}

model Drop {
  id             String        @id @default(uuid())
  name           String        @db.VarChar(200)
  description    String?
  price          Decimal       @db.Decimal(10, 2)
  totalStock     Int           @map("total_stock")
  availableStock Int           @map("available_stock")
  imageUrl       String?       @map("image_url") @db.VarChar(500)
  startsAt       DateTime      @default(now()) @map("starts_at")
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  reservations   Reservation[]
  purchases      Purchase[]

  @@index([isActive, startsAt])
  @@map("drops")
}

model Reservation {
  id        String            @id @default(uuid())
  dropId    String            @map("drop_id")
  userId    String            @map("user_id")
  status    ReservationStatus @default(ACTIVE)
  expiresAt DateTime          @map("expires_at")
  createdAt DateTime          @default(now()) @map("created_at")
  drop      Drop              @relation(fields: [dropId], references: [id])
  user      User              @relation(fields: [userId], references: [id])
  purchase  Purchase?

  @@index([dropId, userId, status])
  @@index([expiresAt, status])
  @@map("reservations")
}

model Purchase {
  id            String      @id @default(uuid())
  reservationId String      @unique @map("reservation_id")
  dropId        String      @map("drop_id")
  userId        String      @map("user_id")
  pricePaid     Decimal     @map("price_paid") @db.Decimal(10, 2)
  createdAt     DateTime    @default(now()) @map("created_at")
  drop          Drop        @relation(fields: [dropId], references: [id])
  user          User        @relation(fields: [userId], references: [id])
  reservation   Reservation @relation(fields: [reservationId], references: [id])

  @@index([dropId, createdAt])
  @@map("purchases")
}

enum ReservationStatus {
  ACTIVE
  EXPIRED
  PURCHASED
}
